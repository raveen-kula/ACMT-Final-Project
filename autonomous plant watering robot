#include <ESP32Servo.h>

Servo myServo;
#define SERVO_PIN 27  

#define SOIL_SENSOR 39
#define RELAY_PIN 23

// Soil level ( Change after testing )
int wetThreshold = 2000;

// IR Sensors
#define IR1 32
#define IR2 33
#define IR3 34
#define IR4 35

#define IR5 13

// Ultrasonic sensor
#define TRIG 25
#define ECHO 26

// L298N driver
#define IN1 18
#define IN2 19
#define IN3 21
#define IN4 22

// Motor speed level
int s = 100;

bool obstacle = false;

void setup()
{
  Serial.begin(115200);

  myServo.attach(SERVO_PIN);
  myServo.write(0);

  pinMode(IR1, INPUT);
  pinMode(IR2, INPUT);
  pinMode(IR3, INPUT);
  pinMode(IR4, INPUT);
  pinMode(IR5, INPUT);

  pinMode(TRIG, OUTPUT);
  pinMode(ECHO, INPUT);

  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);

  pinMode(RELAY_PIN, OUTPUT);
  digitalWrite(RELAY_PIN, LOW);
}

void loop()
{
  int distance = getDistance();

  Serial.print("Distance: ");
  Serial.println(distance);

  //  -------------- OBSTACLE DETECT --------------
  if (distance > 0 && distance < 15)  // When Detect Distance with in 15cm
  {
    obstacle = true;
    stopMotors();
    return;   // STOP everything
  }

  //  -------------- OBSTACLE REMOVED  --------------
  if (obstacle && distance >= 15)
  {
    obstacle = false;   // resume tracking
  }

    //  -------------- IR5 MARKER CHECK  --------------  Detect plant plase
  if (digitalRead(IR5) == HIGH)
  {
    stopMotors();
    delay(1000);
    
      // 0 to 120 degrees
    myServo.write(120);
    Serial.println("120°");
    delay(1000);

      // Check soil
      int soilValue = analogRead(SOIL_SENSOR);

      Serial.print("Soil Value = ");
      Serial.println(soilValue);

      // Wet soil detected
      if (soilValue < wetThreshold)
      {
        digitalWrite(RELAY_PIN, HIGH);   // Relay ON
        delay(1000);                     // 1 second
        digitalWrite(RELAY_PIN, LOW);    // Relay OFF
        forward();
        delay(25);
      }else {
        digitalWrite(RELAY_PIN, LOW);    // Relay OFF
        forward();
        delay(25);
      }

      // 120 to 0 degrees
    myServo.write(0);
    Serial.println("0°");
    delay(1000);

    return;   // go back to loop
  }

  if (!obstacle)
  {
    lineFollow();
  }

  delay(10);
}

//  -------------- LINE FOLLOW  --------------
void lineFollow()
{
  int s1 = digitalRead(IR1);
  int s2 = digitalRead(IR2);
  int s3 = digitalRead(IR3);
  int s4 = digitalRead(IR4);

  // BLACK = LOW (change if needed)

  if (s2 == LOW && s3 == LOW)
  {
    forward();
  }
  else if (s1 == LOW)
  {
    right();
  }
  else if (s2 == LOW)
  {
    right();
  }
  else if (s3 == LOW)
  {
    left();
  }
  else if (s4 == LOW)
  {
    left();
  }else if (s1 == LOW && s2 == LOW && s3 == LOW && s4 == LOW) {
    stopMotors();
  }
  else
  {
    stopMotors();
  }
}

//  -------------- ULTRASONIC --------------
int getDistance()
{
  digitalWrite(TRIG, LOW);
  delayMicroseconds(2);

  digitalWrite(TRIG, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG, LOW);

  long duration = pulseIn(ECHO, HIGH, 30000);

  int distance = duration * 0.034 / 2;

  return distance;
}



void forward()
{
  analogWrite(IN1, s);
  analogWrite(IN2, LOW);

  analogWrite(IN3, s);
  analogWrite(IN4, LOW);
}

void left()
{
  analogWrite(IN1, LOW);
  analogWrite(IN2, s);

  analogWrite(IN3, s);
  analogWrite(IN4, LOW);
}

void right()
{
  analogWrite(IN1, s);
  analogWrite(IN2, LOW);

  analogWrite(IN3, LOW);
  analogWrite(IN4, s);
}

void stopMotors()
{
  analogWrite(IN1, LOW);
  analogWrite(IN2, LOW);

  analogWrite(IN3, LOW);
  analogWrite(IN4, LOW);
}


